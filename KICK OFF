<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI 활용 역량 강화 중급 과정 개발 프로젝트</title>

<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap');

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --blue:#3b82f6;
  --indigo:#6366f1;
  --purple:#8b5cf6;
  --green:#10b981;
  --amber:#f59e0b;
  --rose:#f43f5e;
  --dark:#0f172a;
  --text:#1e293b;
  --text2:#334155;
  --text3:#475569;
  --muted:#94a3b8;
  --line:rgba(15,23,42,.07);
  --bg:#f8fafc;
  --white:#ffffff;
  --grad1:linear-gradient(135deg,#667eea 0%,#764ba2 100%);
  --grad2:linear-gradient(135deg,#4facfe 0%,#00f2fe 100%);
  --grad3:linear-gradient(135deg,#43e97b 0%,#38f9d7 100%);
  --grad4:linear-gradient(135deg,#fa709a 0%,#fee140 100%);
  --grad5:linear-gradient(135deg,#f093fb 0%,#f5576c 100%);
}

html{font-size:16px;scroll-behavior:smooth}

body{
  font-family:'Noto Sans KR',system-ui,sans-serif;
  background:var(--bg);
  color:var(--text);
  overflow-x:hidden;
}

#particles{
  position:fixed;
  inset:0;
  z-index:0;
  pointer-events:none;
}

.nav{
  position:fixed;
  top:0;
  left:0;
  right:0;
  z-index:1000;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:1rem;
  padding:1rem 2rem;
  background:rgba(255,255,255,.9);
  backdrop-filter:blur(18px);
  border-bottom:1px solid var(--line);
  box-shadow:0 1px 4px rgba(15,23,42,.05);
}

.nav-logo{
  font-weight:900;
  font-size:1.05rem;
  white-space:nowrap;
  background:var(--grad1);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}

.nav-links{
  display:flex;
  flex-wrap:wrap;
  justify-content:flex-end;
  gap:.35rem;
}

.nav-links a{
  text-decoration:none;
  color:#64748b;
  font-size:.76rem;
  font-weight:700;
  padding:.4rem .65rem;
  border-radius:9px;
  transition:.25s;
}

.nav-links a:hover,
.nav-links a.active{
  background:rgba(99,102,241,.1);
  color:#4338ca;
}

.nav-progress{
  position:absolute;
  left:0;
  bottom:0;
  height:2px;
  width:0;
  background:var(--grad1);
}

.section{
  min-height:100vh;
  position:relative;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:6.5rem 2rem 4rem;
  overflow:hidden;
}

.content{
  position:relative;
  z-index:2;
  width:100%;
  max-width:1240px;
}

.bg-orbs{
  position:absolute;
  inset:0;
  overflow:hidden;
  pointer-events:none;
}

.orb{
  position:absolute;
  border-radius:999px;
  filter:blur(96px);
  opacity:.14;
  animation:orbFloat 20s ease-in-out infinite;
}

.orb:nth-child(1){
  width:560px;
  height:560px;
  background:#818cf8;
  top:-18%;
  left:-12%;
}

.orb:nth-child(2){
  width:480px;
  height:480px;
  background:#60a5fa;
  right:-12%;
  bottom:-18%;
  animation-delay:-7s;
}

.orb:nth-child(3){
  width:380px;
  height:380px;
  background:#c084fc;
  left:45%;
  top:45%;
  animation-delay:-14s;
}

@keyframes orbFloat{
  0%,100%{transform:translate(0,0) scale(1)}
  33%{transform:translate(32px,-44px) scale(1.08)}
  66%{transform:translate(-22px,36px) scale(.92)}
}

.grid-bg{
  position:absolute;
  inset:0;
  background-image:
    linear-gradient(rgba(99,102,241,.045) 1px,transparent 1px),
    linear-gradient(90deg,rgba(99,102,241,.045) 1px,transparent 1px);
  background-size:60px 60px;
  pointer-events:none;
}

.reveal,
.reveal-scale,
.stagger>*{
  opacity:0;
  transition:all .75s cubic-bezier(.16,1,.3,1);
}

.reveal{transform:translateY(36px)}
.reveal.visible{opacity:1;transform:translateY(0)}

.reveal-scale{transform:scale(.9)}
.reveal-scale.visible{opacity:1;transform:scale(1)}

.stagger>*{transform:translateY(28px)}
.stagger.visible>*{opacity:1;transform:translateY(0)}
.stagger.visible>*:nth-child(1){transition-delay:.04s}
.stagger.visible>*:nth-child(2){transition-delay:.08s}
.stagger.visible>*:nth-child(3){transition-delay:.12s}
.stagger.visible>*:nth-child(4){transition-delay:.16s}
.stagger.visible>*:nth-child(5){transition-delay:.2s}
.stagger.visible>*:nth-child(6){transition-delay:.24s}
.stagger.visible>*:nth-child(7){transition-delay:.28s}
.stagger.visible>*:nth-child(8){transition-delay:.32s}

.gradient{
  background:var(--grad1);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}

.sec-label{
  color:#4f46e5;
  font-size:.72rem;
  font-weight:900;
  letter-spacing:.15em;
  text-transform:uppercase;
  margin-bottom:.55rem;
}

.sec-title{
  font-size:2.1rem;
  font-weight:900;
  line-height:1.28;
  color:#1e293b;
  margin-bottom:.6rem;
}

.sec-desc{
  max-width:880px;
  color:#64748b;
  font-size:1rem;
  line-height:1.75;
  margin-bottom:2.3rem;
}

.glass{
  background:rgba(255,255,255,.82);
  border:1px solid var(--line);
  border-radius:24px;
  padding:2rem;
  box-shadow:0 6px 28px rgba(15,23,42,.055);
  backdrop-filter:blur(18px);
}

.glass:hover{
  border-color:rgba(99,102,241,.22);
  box-shadow:0 14px 42px rgba(99,102,241,.09);
}

/* Cover */
#cover{
  text-align:center;
  background:linear-gradient(180deg,#eef2ff 0%,#f8fafc 100%);
}

.cover-tag{
  display:inline-block;
  padding:.55rem 1.45rem;
  border-radius:999px;
  background:rgba(99,102,241,.1);
  border:1px solid rgba(99,102,241,.22);
  color:#4f46e5;
  font-size:.84rem;
  font-weight:800;
  letter-spacing:.08em;
  margin-bottom:2rem;
  animation:fadeInDown .8s .15s both;
}

.cover-title{
  font-size:clamp(2.55rem,5vw,4.2rem);
  line-height:1.18;
  font-weight:900;
  margin-bottom:1.35rem;
  animation:fadeInUp .9s .35s both;
}

.cover-sub{
  color:#64748b;
  font-size:1.16rem;
  line-height:1.75;
  margin-bottom:2.2rem;
  animation:fadeInUp .9s .55s both;
}

.cover-meta{
  color:#64748b;
  font-size:.95rem;
  line-height:2;
  animation:fadeInUp .9s .75s both;
}

.cover-meta strong{color:#1e293b}

.keyword-wrap{
  margin-top:2rem;
  display:flex;
  justify-content:center;
  flex-wrap:wrap;
  gap:.65rem;
  animation:fadeInUp .9s .95s both;
}

.keyword{
  display:inline-flex;
  align-items:center;
  gap:.35rem;
  padding:.5rem .9rem;
  border-radius:999px;
  background:rgba(255,255,255,.8);
  border:1px solid rgba(99,102,241,.12);
  color:#475569;
  font-size:.8rem;
  font-weight:800;
  box-shadow:0 6px 18px rgba(15,23,42,.04);
}

.cover-scroll{
  position:absolute;
  left:50%;
  bottom:2.8rem;
  transform:translateX(-50%);
  animation:bounce 2s infinite;
}

.cover-scroll span{
  display:block;
  width:24px;
  height:38px;
  border:2px solid #94a3b8;
  border-radius:13px;
  position:relative;
}

.cover-scroll span::after{
  content:'';
  position:absolute;
  top:6px;
  left:50%;
  width:4px;
  height:8px;
  border-radius:5px;
  background:#6366f1;
  transform:translateX(-50%);
  animation:scrollDot 2s infinite;
}

@keyframes fadeInDown{
  from{opacity:0;transform:translateY(-28px)}
  to{opacity:1;transform:translateY(0)}
}

@keyframes fadeInUp{
  from{opacity:0;transform:translateY(28px)}
  to{opacity:1;transform:translateY(0)}
}

@keyframes bounce{
  0%,100%{transform:translateX(-50%) translateY(0)}
  50%{transform:translateX(-50%) translateY(10px)}
}

@keyframes scrollDot{
  0%{opacity:1;top:6px}
  100%{opacity:0;top:21px}
}

/* Cards */
.info-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
  gap:1.3rem;
}

.info-item{
  display:flex;
  gap:1rem;
  align-items:flex-start;
}

.info-icon{
  flex:0 0 auto;
  width:50px;
  height:50px;
  border-radius:16px;
  display:flex;
  align-items:center;
  justify-content:center;
  color:white;
  font-size:1.35rem;
}

.info-text h4{
  color:#1e293b;
  font-size:.95rem;
  font-weight:900;
  margin-bottom:.25rem;
}

.info-text p{
  color:#64748b;
  font-size:.86rem;
  line-height:1.58;
}

.phase-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:1.6rem;
  margin-top:1.6rem;
}

.phase-card{
  border-radius:24px;
  padding:2.2rem;
  box-shadow:0 6px 26px rgba(15,23,42,.055);
}

.phase-card.p1{
  background:linear-gradient(135deg,rgba(59,130,246,.08),rgba(99,102,241,.055));
  border:1px solid rgba(59,130,246,.18);
}

.phase-card.p2{
  background:linear-gradient(135deg,rgba(245,158,11,.08),rgba(244,63,94,.055));
  border:1px solid rgba(245,158,11,.18);
}

.phase-tag{
  display:inline-block;
  margin-bottom:1rem;
  padding:.32rem .85rem;
  border-radius:999px;
  font-size:.7rem;
  font-weight:900;
  letter-spacing:.1em;
  text-transform:uppercase;
}

.phase-card.p1 .phase-tag{background:rgba(59,130,246,.12);color:#2563eb}
.phase-card.p2 .phase-tag{background:rgba(245,158,11,.12);color:#d97706}

.phase-card h3{
  font-size:1.3rem;
  font-weight:900;
  margin-bottom:.35rem;
}

.period{
  color:#64748b;
  font-size:.9rem;
  margin-bottom:1rem;
}

.phase-card ul{list-style:none}

.phase-card li{
  position:relative;
  padding:.4rem 0 .4rem 1.45rem;
  color:#475569;
  font-size:.9rem;
  line-height:1.55;
}

.phase-card li::before{
  content:'';
  position:absolute;
  left:0;
  top:.8rem;
  width:8px;
  height:8px;
  border-radius:50%;
}

.phase-card.p1 li::before{background:#3b82f6}
.phase-card.p2 li::before{background:#f59e0b}

.phase-note{
  margin-top:.8rem;
  padding-top:.7rem;
  border-top:1px dashed rgba(15,23,42,.12);
  color:#94a3b8;
  font-size:.78rem;
  font-style:italic;
}

/* Stats */
.stats-row{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:1.25rem;
  margin-top:2rem;
}

.stat-card{
  position:relative;
  overflow:hidden;
  text-align:center;
  border-radius:20px;
  padding:1.7rem 1rem;
  background:rgba(255,255,255,.84);
  border:1px solid var(--line);
  box-shadow:0 6px 24px rgba(15,23,42,.05);
}

.stat-card::before{
  content:'';
  position:absolute;
  top:0;
  left:0;
  right:0;
  height:3px;
}

.stat-card:nth-child(1)::before{background:var(--grad1)}
.stat-card:nth-child(2)::before{background:var(--grad2)}
.stat-card:nth-child(3)::before{background:var(--grad3)}
.stat-card:nth-child(4)::before{background:var(--grad4)}

.stat-value{
  font-size:2.35rem;
  font-weight:900;
  margin-bottom:.25rem;
}

.stat-card:nth-child(1) .stat-value{background:var(--grad1);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.stat-card:nth-child(2) .stat-value{background:var(--grad2);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.stat-card:nth-child(3) .stat-value{background:var(--grad3);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.stat-card:nth-child(4) .stat-value{background:var(--grad4);-webkit-background-clip:text;-webkit-text-fill-color:transparent}

.stat-label{
  color:#64748b;
  font-size:.82rem;
  font-weight:800;
}

.stat-bar{
  height:4px;
  margin-top:1rem;
  border-radius:99px;
  background:rgba(15,23,42,.07);
  overflow:hidden;
}

.stat-fill{
  height:100%;
  width:0;
  border-radius:99px;
  transition:width 1.4s cubic-bezier(.16,1,.3,1);
}

.stat-card:nth-child(1) .stat-fill{background:var(--grad1)}
.stat-card:nth-child(2) .stat-fill{background:var(--grad2)}
.stat-card:nth-child(3) .stat-fill{background:var(--grad3)}
.stat-card:nth-child(4) .stat-fill{background:var(--grad4)}

/* Concept */
.concept-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:1.2rem;
}

.concept-card{
  padding:1.55rem;
  border-radius:22px;
  background:rgba(255,255,255,.84);
  border:1px solid var(--line);
  box-shadow:0 6px 24px rgba(15,23,42,.05);
}

.concept-num{
  width:36px;
  height:36px;
  border-radius:50%;
  display:flex;
  align-items:center;
  justify-content:center;
  color:white;
  font-weight:900;
  margin-bottom:.85rem;
}

.concept-card h4{
  font-size:.98rem;
  font-weight:900;
  margin-bottom:.4rem;
}

.concept-card p{
  color:#64748b;
  font-size:.84rem;
  line-height:1.62;
}

/* Curriculum */
.curr-wrap{
  overflow-x:auto;
  border-radius:20px;
  background:white;
  border:1px solid var(--line);
  box-shadow:0 6px 28px rgba(15,23,42,.055);
}

.curr-table{
  width:100%;
  border-collapse:collapse;
  font-size:.88rem;
}

.curr-table th{
  padding:.95rem 1rem;
  background:rgba(99,102,241,.085);
  color:#4f46e5;
  text-align:left;
  font-size:.78rem;
  font-weight:900;
  letter-spacing:.08em;
  text-transform:uppercase;
  border-bottom:1px solid var(--line);
  white-space:nowrap;
}

.curr-table td{
  padding:.85rem 1rem;
  border-bottom:1px solid rgba(15,23,42,.045);
  color:#475569;
  line-height:1.58;
  vertical-align:top;
}

.curr-table tr:hover td{
  background:rgba(99,102,241,.03);
}

.curr-table .module-row td{
  background:rgba(99,102,241,.065);
  color:#4f46e5;
  font-weight:900;
  font-size:.86rem;
}

.curr-table td:first-child{
  text-align:center;
  color:#6366f1;
  font-weight:900;
  white-space:nowrap;
}

.curr-table td:nth-child(3){
  text-align:center;
  color:#64748b;
  white-space:nowrap;
}

.curr-table td:last-child{text-align:center}

.instructor-badge{
  display:inline-block;
  width:29px;
  height:29px;
  line-height:29px;
  text-align:center;
  border-radius:50%;
  color:white;
  font-size:.75rem;
  font-weight:900;
}

.instructor-badge.a{background:linear-gradient(135deg,#3b82f6,#6366f1)}
.instructor-badge.b{background:linear-gradient(135deg,#10b981,#14b8a6)}
.instructor-badge.c{background:linear-gradient(135deg,#f59e0b,#f97316)}
.instructor-badge.d{background:linear-gradient(135deg,#f43f5e,#e879f9)}

.practice-badge{
  display:inline-block;
  margin-top:.4rem;
  padding:.22rem .6rem;
  border-radius:8px;
  background:rgba(16,185,129,.09);
  color:#059669;
  font-size:.72rem;
  font-weight:900;
}

/* Prompt */
.framework{
  display:grid;
  grid-template-columns:1.15fr .85fr;
  gap:1.4rem;
}

.prompt-box{
  border-radius:24px;
  padding:2rem;
  background:rgba(255,255,255,.84);
  border:1px solid var(--line);
  box-shadow:0 6px 26px rgba(15,23,42,.055);
}

.prompt-steps{
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:.9rem;
}

.prompt-step{
  padding:1rem;
  border-radius:16px;
  background:rgba(99,102,241,.055);
  border:1px solid rgba(99,102,241,.12);
}

.prompt-step strong{
  display:block;
  color:#4338ca;
  font-size:.86rem;
  margin-bottom:.25rem;
}

.prompt-step span{
  color:#64748b;
  font-size:.82rem;
  line-height:1.5;
}

.formula{
  color:#1e293b;
  font-size:1.02rem;
  line-height:1.85;
  font-weight:800;
}

.formula small{
  display:block;
  margin-top:.85rem;
  color:#64748b;
  font-size:.84rem;
  line-height:1.65;
  font-weight:600;
}

/* Output */
.output-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:1.2rem;
}

.output-card{
  padding:1.55rem;
  border-radius:22px;
  background:rgba(255,255,255,.84);
  border:1px solid var(--line);
  box-shadow:0 6px 24px rgba(15,23,42,.05);
}

.output-icon{
  width:46px;
  height:46px;
  border-radius:15px;
  display:flex;
  align-items:center;
  justify-content:center;
  color:white;
  font-size:1.25rem;
  margin-bottom:.9rem;
}

.output-card h4{
  font-size:.98rem;
  font-weight:900;
  margin-bottom:.4rem;
}

.output-card p{
  color:#64748b;
  font-size:.84rem;
  line-height:1.6;
}

/* Timeline */
.timeline{
  position:relative;
  margin-top:2rem;
}

.timeline::before{
  content:'';
  position:absolute;
  left:24px;
  top:0;
  bottom:0;
  width:2px;
  background:linear-gradient(to bottom,#6366f1,#3b82f6,#10b981,#f59e0b,#f43f5e);
}

.tl-item{
  position:relative;
  padding-left:60px;
  margin-bottom:2rem;
}

.tl-dot{
  position:absolute;
  left:15px;
  top:4px;
  width:20px;
  height:20px;
  border-radius:50%;
  background:white;
  border:3px solid #6366f1;
}

.tl-dot::after{
  content:'';
  position:absolute;
  inset:4px;
  border-radius:50%;
  background:#6366f1;
}

.tl-item:nth-child(2) .tl-dot{border-color:#3b82f6}
.tl-item:nth-child(2) .tl-dot::after{background:#3b82f6}
.tl-item:nth-child(3) .tl-dot{border-color:#10b981}
.tl-item:nth-child(3) .tl-dot::after{background:#10b981}
.tl-item:nth-child(4) .tl-dot{border-color:#f59e0b}
.tl-item:nth-child(4) .tl-dot::after{background:#f59e0b}
.tl-item:nth-child(5) .tl-dot{border-color:#f43f5e}
.tl-item:nth-child(5) .tl-dot::after{background:#f43f5e}

.tl-phase-label{
  display:inline-block;
  margin-bottom:.35rem;
  padding:.22rem .62rem;
  border-radius:8px;
  background:rgba(99,102,241,.08);
  color:#4f46e5;
  font-size:.68rem;
  font-weight:900;
  letter-spacing:.1em;
  text-transform:uppercase;
}

.tl-date{
  color:#6366f1;
  font-size:.78rem;
  font-weight:900;
  margin-bottom:.2rem;
}

.tl-title{
  color:#1e293b;
  font-size:1rem;
  font-weight:900;
  margin-bottom:.3rem;
}

.tl-desc{
  color:#64748b;
  font-size:.85rem;
  line-height:1.58;
}

.tl-output{
  display:inline-block;
  margin-top:.45rem;
  padding:.24rem .65rem;
  border-radius:8px;
  background:rgba(99,102,241,.08);
  color:#4f46e5;
  font-size:.75rem;
  font-weight:900;
}

/* Rotation */
.rotation-ring{
  display:flex;
  justify-content:center;
  gap:0;
  margin:2rem 0;
}

.rot-person{
  position:relative;
  text-align:center;
  padding:1rem 2rem;
}

.rot-person::after{
  content:'→';
  position:absolute;
  right:-7px;
  top:50%;
  transform:translateY(-50%);
  color:#94a3b8;
  font-size:1.5rem;
  font-weight:900;
}

.rot-person:last-child::after{
  content:'↩';
  color:#6366f1;
}

.rot-avatar{
  width:64px;
  height:64px;
  margin:0 auto .6rem;
  border-radius:50%;
  display:flex;
